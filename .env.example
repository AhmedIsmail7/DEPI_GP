# VideoInsight V2.0 - Configuration Variables
# Rename this file to .env and configure your keys

# Qdrant Database (Phase 4)
QDRANT_API_KEY=your_qdrant_cloud_api_key_here
QDRANT_URL=https://your-qdrant-cluster-url.aws.qdrant.io:6333

# Gemini API (Phase 5)
GEMINI_API_KEY=your_gemini_api_key_here

# System Settings
DEBUG=False
