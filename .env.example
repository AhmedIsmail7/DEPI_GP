# Copy this file to .env and fill in your values. Do NOT commit your .env file.

# Video source (optional)
VIDEO_URL=https://youtu.be/PUT_YOUR_VIDEO_HERE

# Qdrant (vector DB)
QDRANT_URL=
QDRANT_API_KEY=

# Cohere (LLM)
COHERE_API_KEY=

# Optional third-party keys
GOOGLE_API_KEY=

# Local settings
TEMP_DIR=temp_assets

# Example:
# VIDEO_URL=https://youtu.be/rEDzUT3ymw4
# COHERE_API_KEY=cohere_xxx
